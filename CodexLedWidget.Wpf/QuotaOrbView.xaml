<UserControl x:Class="CodexLedWidget.Wpf.QuotaOrbView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="118"
             Height="118"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="Auto">
    <Grid Width="118" Height="118">
        <Grid SnapsToDevicePixels="True">
            <Grid.Clip>
                <EllipseGeometry Center="59,59" RadiusX="59" RadiusY="59" />
            </Grid.Clip>

            <Ellipse>
                <Ellipse.Fill>
                    <RadialGradientBrush Center="0.33,0.22"
                                         GradientOrigin="0.22,0.12"
                                         RadiusX="0.9"
                                         RadiusY="0.9">
                        <GradientStop Color="#FCFFFFFF" Offset="0" />
                        <GradientStop Color="#D8F2FAFF" Offset="0.42" />
                        <GradientStop Color="#A8DDEBFF" Offset="1" />
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <Grid x:Name="PrimaryHalfFill"
                  Width="59"
                  Height="0"
                  HorizontalAlignment="Left"
                  VerticalAlignment="Bottom"
                  ClipToBounds="True">
                <Ellipse Width="6"
                         Height="6"
                         Margin="10,24,0,0"
                         HorizontalAlignment="Left"
                         VerticalAlignment="Top"
                         Fill="#66FFFFFF">
                    <Ellipse.RenderTransform>
                        <TranslateTransform x:Name="PrimaryBubbleA" />
                    </Ellipse.RenderTransform>
                    <Ellipse.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                    <DoubleAnimation Storyboard.TargetName="PrimaryBubbleA"
                                                     Storyboard.TargetProperty="Y"
                                                     From="0"
                                                     To="-7"
                                                     Duration="0:0:3.4" />
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     From="0.35"
                                                     To="0.85"
                                                     Duration="0:0:3.4" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Ellipse.Triggers>
                </Ellipse>
                <Ellipse Width="3.5"
                         Height="3.5"
                         Margin="39,38,0,0"
                         HorizontalAlignment="Left"
                         VerticalAlignment="Top"
                         Fill="#72C8FFF0" />
            </Grid>

            <Grid x:Name="SecondaryHalfFill"
                  Width="59"
                  Height="0"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Bottom"
                  ClipToBounds="True">
                <Ellipse Width="5"
                         Height="5"
                         Margin="14,26,0,0"
                         HorizontalAlignment="Left"
                         VerticalAlignment="Top"
                         Fill="#6EDAF7FF">
                    <Ellipse.RenderTransform>
                        <TranslateTransform x:Name="SecondaryBubbleA" />
                    </Ellipse.RenderTransform>
                    <Ellipse.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                    <DoubleAnimation Storyboard.TargetName="SecondaryBubbleA"
                                                     Storyboard.TargetProperty="Y"
                                                     From="0"
                                                     To="-5"
                                                     Duration="0:0:3.9" />
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     From="0.3"
                                                     To="0.8"
                                                     Duration="0:0:3.9" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Ellipse.Triggers>
                </Ellipse>
                <Ellipse Width="3"
                         Height="3"
                         Margin="41,35,0,0"
                         HorizontalAlignment="Left"
                         VerticalAlignment="Top"
                         Fill="#7CFFFFFF" />
            </Grid>

            <Ellipse Width="130"
                     Height="48"
                     Margin="-6,75,-6,-5"
                     VerticalAlignment="Bottom"
                     Opacity="0.24">
                <Ellipse.Fill>
                    <RadialGradientBrush Center="0.5,0.72"
                                         GradientOrigin="0.5,0.72"
                                         RadiusX="0.62"
                                         RadiusY="0.42">
                        <GradientStop Color="#5537474A" Offset="0" />
                        <GradientStop Color="#1637474A" Offset="0.58" />
                        <GradientStop Color="#0037474A" Offset="1" />
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <Ellipse Width="92"
                     Height="74"
                     Margin="11,8,0,0"
                     HorizontalAlignment="Left"
                     VerticalAlignment="Top"
                     Opacity="0.56">
                <Ellipse.Fill>
                    <RadialGradientBrush Center="0.34,0.18"
                                         GradientOrigin="0.24,0.1"
                                         RadiusX="0.6"
                                         RadiusY="0.72">
                        <GradientStop Color="#B8FFFFFF" Offset="0" />
                        <GradientStop Color="#40FFFFFF" Offset="0.55" />
                        <GradientStop Color="#00FFFFFF" Offset="1" />
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <Path Data="M24,22 C35,12 54,8 72,13"
                  Stroke="#95FFFFFF"
                  StrokeThickness="2.2"
                  StrokeStartLineCap="Round"
                  StrokeEndLineCap="Round"
                  Opacity="0.72" />

            <Rectangle Width="1"
                       HorizontalAlignment="Center"
                       Fill="#243747"
                       Opacity="0.13" />
        </Grid>

        <Ellipse Stroke="#6638FBD2"
                 StrokeThickness="2.2"
                 Fill="Transparent"
                 Margin="-2" />
        <Ellipse Stroke="#6F7DD3FF"
                 StrokeThickness="1.6"
                 Fill="Transparent"
                 Margin="3" />
        <Ellipse Stroke="#70FFFFFF"
                 StrokeThickness="2"
                 Fill="Transparent"
                 Margin="1" />
        <Ellipse Stroke="#2837474A"
                 StrokeThickness="1"
                 Fill="Transparent" />

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock x:Name="PrimaryMeterLabel"
                           Text="5h"
                           FontSize="10"
                           LineHeight="14"
                           LineStackingStrategy="BlockLineHeight"
                           FontWeight="SemiBold"
                           TextAlignment="Center"
                           Foreground="{StaticResource WidgetMutedBrush}" />
                <TextBlock x:Name="PrimaryMeterPercent"
                           Text="--"
                           Margin="0,4,0,0"
                           FontSize="17"
                           LineHeight="24"
                           LineStackingStrategy="BlockLineHeight"
                           FontWeight="Bold"
                           TextAlignment="Center"
                           Foreground="{StaticResource WidgetTextBrush}" />
            </StackPanel>

            <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock x:Name="SecondaryMeterLabel"
                           Text="1w"
                           FontSize="10"
                           LineHeight="14"
                           LineStackingStrategy="BlockLineHeight"
                           FontWeight="SemiBold"
                           TextAlignment="Center"
                           Foreground="{StaticResource WidgetMutedBrush}" />
                <TextBlock x:Name="SecondaryMeterPercent"
                           Text="--"
                           Margin="0,4,0,0"
                           FontSize="17"
                           LineHeight="24"
                           LineStackingStrategy="BlockLineHeight"
                           FontWeight="Bold"
                           TextAlignment="Center"
                           Foreground="{StaticResource WidgetTextBrush}" />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
