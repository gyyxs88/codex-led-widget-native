<Application x:Class="CodexLedWidget.Wpf.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="WidgetTextBrush" Color="#122033" />
        <SolidColorBrush x:Key="WidgetMutedBrush" Color="#526273" />
        <SolidColorBrush x:Key="WidgetLineBrush" Color="#243747" Opacity="0.12" />

        <Style x:Key="WidgetButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Margin" Value="3,0,0,0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource WidgetTextBrush}" />
            <Setter Property="Background" Value="#88FFFFFF" />
            <Setter Property="BorderBrush" Value="#1F283747" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#DDFFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WidgetTextButtonStyle" TargetType="Button" BasedOn="{StaticResource WidgetButtonStyle}">
            <Setter Property="Width" Value="34" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="QuotaCardStyle" TargetType="Border">
            <Setter Property="Height" Value="50" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="BorderBrush" Value="#1A283747" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#B8FFFFFF" />
        </Style>

        <Style x:Key="CardLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="LineHeight" Value="14" />
            <Setter Property="LineStackingStrategy" Value="BlockLineHeight" />
            <Setter Property="Foreground" Value="{StaticResource WidgetMutedBrush}" />
        </Style>

        <Style x:Key="CardValueStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,4,0,0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="LineHeight" Value="17" />
            <Setter Property="LineStackingStrategy" Value="BlockLineHeight" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{StaticResource WidgetTextBrush}" />
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
    </Application.Resources>
</Application>
