<Window x:Class="CodexLedWidget.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Codex LED Widget"
        Icon="Resources/App.ico"
        Width="460"
        Height="292"
        MinWidth="320"
        MinHeight="203"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize"
        ShowInTaskbar="True"
        Topmost="True"
        FontFamily="Microsoft YaHei UI, Segoe UI"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="Auto">
    <Viewbox Stretch="Uniform">
        <Grid Width="440" Height="272" MouseLeftButtonDown="WidgetRoot_MouseLeftButtonDown">
            <Grid.Clip>
                <RectangleGeometry Rect="0,0,440,272" RadiusX="18" RadiusY="18" />
            </Grid.Clip>

            <Border CornerRadius="18"
                    BorderBrush="{StaticResource WidgetLineBrush}"
                    BorderThickness="1">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#FAFFFFFF" Offset="0" />
                        <GradientStop Color="#F1EAF5FF" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <Ellipse Width="170"
                     Height="170"
                     HorizontalAlignment="Left"
                     VerticalAlignment="Bottom"
                     Margin="-50,0,0,-70"
                     Fill="#667BE0BD">
                <Ellipse.Effect>
                    <BlurEffect Radius="22" />
                </Ellipse.Effect>
            </Ellipse>
            <Ellipse Width="170"
                     Height="170"
                     HorizontalAlignment="Right"
                     VerticalAlignment="Top"
                     Margin="0,-64,-54,0"
                     Fill="#558EC5FF">
                <Ellipse.Effect>
                    <BlurEffect Radius="22" />
                </Ellipse.Effect>
            </Ellipse>

            <Grid Margin="14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="54" />
                    <RowDefinition Height="166" />
                    <RowDefinition Height="24" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Top" Margin="4,4,0,0">
                        <Ellipse x:Name="TrafficLight"
                                 Width="17"
                                 Height="17"
                                 Margin="0,7,10,0"
                                 Fill="#18B673" />
                        <StackPanel>
                            <TextBlock Text="Codex 额度"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource WidgetTextBrush}" />
                            <TextBlock x:Name="StateText"
                                       Text="读取中"
                                       Margin="0,2,0,0"
                                       FontSize="12"
                                       Foreground="{StaticResource WidgetMutedBrush}" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Top">
                        <Button x:Name="LanguageButton" Style="{StaticResource WidgetTextButtonStyle}" Content="EN" Click="LanguageButton_Click" />
                        <Button x:Name="PinButton" Style="{StaticResource WidgetButtonStyle}" Foreground="#3B82F6" Click="PinButton_Click">
                            <Path Width="15"
                                  Height="15"
                                  Stretch="Uniform"
                                  Data="M9,3 L15,3 C15.7,3 16.2,3.5 16.2,4.2 L16.2,8 L18.8,10.6 C19.3,11.1 19.3,11.9 18.8,12.4 L17.8,13.4 C17.3,13.9 16.5,13.9 16,13.4 L14,11.4 L14,15.8 L12.8,17 L12.8,21 L11.2,21 L11.2,17 L10,15.8 L10,11.4 L8,13.4 C7.5,13.9 6.7,13.9 6.2,13.4 L5.2,12.4 C4.7,11.9 4.7,11.1 5.2,10.6 L7.8,8 L7.8,4.2 C7.8,3.5 8.3,3 9,3 Z"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                        </Button>
                        <Button Style="{StaticResource WidgetButtonStyle}" Click="RefreshButton_Click">
                            <Grid Width="15" Height="15">
                                <Path Data="M20,12 A8,8 0 0 1 6.3,17.7 M4,12 A8,8 0 0 1 17.7,6.3 M17,3 L17,7 L13,7 M7,21 L7,17 L11,17"
                                      Stretch="Uniform"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      StrokeThickness="2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round" />
                            </Grid>
                        </Button>
                        <Button Style="{StaticResource WidgetButtonStyle}" Click="MinimizeButton_Click">
                            <Path Width="15"
                                  Height="15"
                                  Stretch="Uniform"
                                  Data="M5,12 L19,12"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round" />
                        </Button>
                        <Button Style="{StaticResource WidgetButtonStyle}" Click="CloseButton_Click">
                            <Path Width="15"
                                  Height="15"
                                  Stretch="Uniform"
                                  Data="M6,6 L18,18 M18,6 L6,18"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round" />
                        </Button>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="126" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Grid Width="118"
                          Height="118"
                          HorizontalAlignment="Left"
                          VerticalAlignment="Top"
                          Margin="0,23,0,0">
                        <Grid SnapsToDevicePixels="True">
                            <Grid.Clip>
                                <EllipseGeometry Center="59,59" RadiusX="59" RadiusY="59" />
                            </Grid.Clip>

                            <Ellipse>
                                <Ellipse.Fill>
                                    <RadialGradientBrush Center="0.33,0.22"
                                                         GradientOrigin="0.22,0.12"
                                                         RadiusX="0.86"
                                                         RadiusY="0.86">
                                        <GradientStop Color="#FCFFFFFF" Offset="0" />
                                        <GradientStop Color="#D7F8FCFF" Offset="0.45" />
                                        <GradientStop Color="#B6DDEBFA" Offset="1" />
                                    </RadialGradientBrush>
                                </Ellipse.Fill>
                            </Ellipse>

                            <Border x:Name="PrimaryHalfFill"
                                    Width="59"
                                    Height="0"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Bottom" />
                            <Border x:Name="SecondaryHalfFill"
                                    Width="59"
                                    Height="0"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Bottom" />

                            <Ellipse Width="130"
                                     Height="48"
                                     Margin="-6,75,-6,-5"
                                     VerticalAlignment="Bottom"
                                     Opacity="0.24">
                                <Ellipse.Fill>
                                    <RadialGradientBrush Center="0.5,0.72"
                                                         GradientOrigin="0.5,0.72"
                                                         RadiusX="0.62"
                                                         RadiusY="0.42">
                                        <GradientStop Color="#5537474A" Offset="0" />
                                        <GradientStop Color="#1637474A" Offset="0.58" />
                                        <GradientStop Color="#0037474A" Offset="1" />
                                    </RadialGradientBrush>
                                </Ellipse.Fill>
                            </Ellipse>

                            <Ellipse Width="92"
                                     Height="74"
                                     Margin="11,8,0,0"
                                     HorizontalAlignment="Left"
                                     VerticalAlignment="Top"
                                     Opacity="0.56">
                                <Ellipse.Fill>
                                    <RadialGradientBrush Center="0.34,0.18"
                                                         GradientOrigin="0.24,0.1"
                                                         RadiusX="0.6"
                                                         RadiusY="0.72">
                                        <GradientStop Color="#B8FFFFFF" Offset="0" />
                                        <GradientStop Color="#40FFFFFF" Offset="0.55" />
                                        <GradientStop Color="#00FFFFFF" Offset="1" />
                                    </RadialGradientBrush>
                                </Ellipse.Fill>
                            </Ellipse>

                            <Path Data="M24,22 C35,12 54,8 72,13"
                                  Stroke="#95FFFFFF"
                                  StrokeThickness="2.2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Opacity="0.72" />

                            <Rectangle Width="1"
                                       HorizontalAlignment="Center"
                                       Fill="#243747"
                                       Opacity="0.13" />
                        </Grid>

                        <Ellipse Stroke="#70FFFFFF"
                                 StrokeThickness="2"
                                 Fill="Transparent"
                                 Margin="1" />
                        <Ellipse Stroke="#2837474A"
                                 StrokeThickness="1"
                                 Fill="Transparent" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock x:Name="PrimaryMeterLabel"
                                           Text="5h"
                                           FontSize="10"
                                           LineHeight="14"
                                           LineStackingStrategy="BlockLineHeight"
                                           FontWeight="SemiBold"
                                           TextAlignment="Center"
                                           Foreground="{StaticResource WidgetMutedBrush}" />
                                <TextBlock x:Name="PrimaryMeterPercent"
                                           Text="--"
                                           Margin="0,4,0,0"
                                           FontSize="17"
                                           LineHeight="24"
                                           LineStackingStrategy="BlockLineHeight"
                                           FontWeight="Bold"
                                           TextAlignment="Center"
                                           Foreground="{StaticResource WidgetTextBrush}" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock x:Name="SecondaryMeterLabel"
                                           Text="1w"
                                           FontSize="10"
                                           LineHeight="14"
                                           LineStackingStrategy="BlockLineHeight"
                                           FontWeight="SemiBold"
                                           TextAlignment="Center"
                                           Foreground="{StaticResource WidgetMutedBrush}" />
                                <TextBlock x:Name="SecondaryMeterPercent"
                                           Text="--"
                                           Margin="0,4,0,0"
                                           FontSize="17"
                                           LineHeight="24"
                                           LineStackingStrategy="BlockLineHeight"
                                           FontWeight="Bold"
                                           TextAlignment="Center"
                                           Foreground="{StaticResource WidgetTextBrush}" />
                            </StackPanel>
                        </Grid>
                    </Grid>

                    <StackPanel Grid.Column="1" Margin="12,0,0,0">
                        <Border Style="{StaticResource QuotaCardStyle}">
                            <StackPanel>
                                <TextBlock x:Name="PrimaryLabel" Style="{StaticResource CardLabelStyle}" Text="5小时窗口" />
                                <TextBlock x:Name="PrimaryText" Style="{StaticResource CardValueStyle}" Text="--" />
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource QuotaCardStyle}" Margin="0,7,0,0">
                            <StackPanel>
                                <TextBlock x:Name="SecondaryLabel" Style="{StaticResource CardLabelStyle}" Text="7天窗口" />
                                <TextBlock x:Name="SecondaryText" Style="{StaticResource CardValueStyle}" Text="--" />
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource QuotaCardStyle}" Margin="0,7,0,0">
                            <StackPanel>
                                <TextBlock x:Name="PlanLabel" Style="{StaticResource CardLabelStyle}" Text="计划" />
                                <TextBlock x:Name="PlanText" Style="{StaticResource CardValueStyle}" Text="--" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <StackPanel Grid.Row="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse x:Name="StatusDot"
                             Width="8"
                             Height="8"
                             Fill="#18B673"
                             Margin="4,0,10,0" />
                    <TextBlock x:Name="StatusText"
                               Text="正在读取 Codex 额度..."
                               FontSize="12"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource WidgetMutedBrush}" />
                </StackPanel>
            </Grid>
        </Grid>
    </Viewbox>
</Window>
